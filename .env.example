# Copia este ficheiro para .env.local e preenche.

# MongoDB Atlas (ou local). Atlas -> Database -> Connect -> Drivers.
MONGODB_URI="mongodb+srv://utilizador:password@cluster.xxxxx.mongodb.net/casa-stock?retryWrites=true&w=majority"

# Segredo para assinar os tokens de sessão (JWT). Mete uma string longa e aleatória.
JWT_SECRET="muda-isto-por-uma-string-longa-e-aleatoria"

# Chave da API da Anthropic, para o reconhecimento de produtos por foto (Claude visão).
# Obtém em https://console.anthropic.com/. Sem ela, a app funciona mas o botão de foto fica indisponível.
ANTHROPIC_API_KEY="sk-ant-..."
